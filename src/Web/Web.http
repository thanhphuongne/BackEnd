# For more info on HTTP files go to https://aka.ms/vs/httpfile
@Web_HostAddress = https://localhost:5001
@AuthCookieName = .AspNetCore.Identity.Application
@AuthCookieValue = <AuthCookieValue>

# GET Identity Account Login
# Get the @RequestVerificationToken necessary for logging in.
GET {{Web_HostAddress}}/Identity/Account/Login

###

# POST Identity Account Login
# Get the @AuthCookieValue necessary for authenticating requests.
@Email=administrator@localhost
@Password=Administrator1!
@RequestVerificationToken=<RequestVerificationToken>
POST {{Web_HostAddress}}/Identity/Account/Login
Content-Type: application/x-www-form-urlencoded

Input.Email={{Email}}&Input.Password={{Password}}&__RequestVerificationToken={{RequestVerificationToken}}

###

# GET WeatherForecast
GET {{Web_HostAddress}}/api/WeatherForecasts
Cookie: {{AuthCookieName}}={{AuthCookieValue}}

###

# GET Sports
GET {{Web_HostAddress}}/api/Sports
Cookie: {{AuthCookieName}}={{AuthCookieValue}}

###

# GET Sport by ID
GET {{Web_HostAddress}}/api/Sports/1
Cookie: {{AuthCookieName}}={{AuthCookieValue}}

###

# POST Sports
POST {{Web_HostAddress}}/api/Sports
Cookie: {{AuthCookieName}}={{AuthCookieValue}}
Content-Type: application/json

// CreateSportCommand
{
  "SportName": "Soccer",
  "Description": "Football played with feet"
}

###

# PUT Sports
PUT {{Web_HostAddress}}/api/Sports/1
Cookie: {{AuthCookieName}}={{AuthCookieValue}}
Content-Type: application/json

// UpdateSportCommand
{
  "Id": 1,
  "SportName": "Football",
  "Description": "Updated description"
}

###

# DELETE Sports
DELETE {{Web_HostAddress}}/api/Sports/1
Cookie: {{AuthCookieName}}={{AuthCookieValue}}

###

# GET Fields
@PageNumber = 1
@PageSize = 10
GET {{Web_HostAddress}}/api/Fields?SportId=1&Location=District%207&PageNumber={{PageNumber}}&PageSize={{PageSize}}
Cookie: {{AuthCookieName}}={{AuthCookieValue}}

###

# GET Field Availability
GET {{Web_HostAddress}}/api/Fields/1/availability?date=2025-06-05
Cookie: {{AuthCookieName}}={{AuthCookieValue}}

###

# POST Fields
POST {{Web_HostAddress}}/api/Fields
Cookie: {{AuthCookieName}}={{AuthCookieValue}}
Content-Type: application/json

// CreateFieldCommand
{
  "SportId": 1,
  "FieldName": "Field A",
  "Location": "District 7, Ho Chi Minh City",
  "Capacity": 10,
  "Description": "5-a-side soccer field with lighting"
}

###

# PUT Fields
PUT {{Web_HostAddress}}/api/Fields/1
Cookie: {{AuthCookieName}}={{AuthCookieValue}}
Content-Type: application/json

// UpdateFieldCommand
{
  "Id": 1,
  "FieldName": "Field A - Premium",
  "Location": "District 7, Ho Chi Minh City",
  "Capacity": 12,
  "Description": "Premium 5-a-side soccer field with lighting and sound system"
}

###

# DELETE Fields
DELETE {{Web_HostAddress}}/api/Fields/1
Cookie: {{AuthCookieName}}={{AuthCookieValue}}

###

# GET Bookings
@PageNumber = 1
@PageSize = 10
GET {{Web_HostAddress}}/api/Bookings?CustomerId=1&PageNumber={{PageNumber}}&PageSize={{PageSize}}
Cookie: {{AuthCookieName}}={{AuthCookieValue}}

###

# POST Bookings
POST {{Web_HostAddress}}/api/Bookings
Cookie: {{AuthCookieName}}={{AuthCookieValue}}
Content-Type: application/json

// CreateBookingCommand
{
  "FieldId": 1,
  "SportId": 1,
  "BookingDate": "2025-06-05",
  "StartTime": "18:00:00",
  "EndTime": "19:30:00"
}

###

# PUT Bookings
PUT {{Web_HostAddress}}/api/Bookings/1
Cookie: {{AuthCookieName}}={{AuthCookieValue}}
Content-Type: application/json

// UpdateBookingCommand
{
  "Id": 1,
  "Status": "Confirmed"
}

###

# DELETE Bookings
DELETE {{Web_HostAddress}}/api/Bookings/1
Cookie: {{AuthCookieName}}={{AuthCookieValue}}

###